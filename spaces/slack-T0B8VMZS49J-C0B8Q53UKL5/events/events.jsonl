{"schema_version":1,"id":"evt_1780796687543_68563","type":"paper_recorded","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:44:47.543711+00:00","actor":{},"payload":{"seminar_id":"S1","paper_id":"1706.03762","title":"1706.03762","url":"https://arxiv.org/abs/1706.03762"}}
{"schema_version":1,"id":"evt_1780796715521_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.521279+00:00","actor":{},"payload":{"claim_id":"C1","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"纯注意力可替代循环与卷积","statement":"Transformer 在序列转导任务中可以完全去掉循环网络和卷积网络，仅依靠注意力机制完成编码与解码。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715563_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.563742+00:00","actor":{},"payload":{"claim_id":"C2","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"堆叠自注意力足以建模输入表示","statement":"编码器中由多头自注意力层和逐位置前馈层组成的堆叠结构足以把输入序列映射为有效的连续表示。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715606_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.606912+00:00","actor":{},"payload":{"claim_id":"C3","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"解码器可用遮蔽自注意力保持自回归","statement":"在解码器自注意力中屏蔽未来位置可以保证第 i 个输出只依赖已知的前序输出。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715649_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.649460+00:00","actor":{},"payload":{"claim_id":"C4","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"位置编码补偿无序结构","statement":"由于模型没有循环或卷积，必须向词嵌入加入位置编码，模型才能利用序列顺序信息。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715692_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.692538+00:00","actor":{},"payload":{"claim_id":"C5","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"正弦位置编码可表达相对位移","statement":"所采用的正弦/余弦位置编码使固定偏移位置的编码可由当前位置编码的线性函数表示，从而便于模型学习相对位置关系。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715734_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.734626+00:00","actor":{},"payload":{"claim_id":"C6","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"缩放点积注意力稳定训练","statement":"将查询与键的点积除以 sqrt(d_k) 可以缓解高维点积过大导致 softmax 梯度过小的问题。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715777_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.777711+00:00","actor":{},"payload":{"claim_id":"C7","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"多头注意力提升表达能力","statement":"多头注意力允许模型在不同表示子空间和不同位置上并行关注信息，比单头注意力更能避免单一加权平均造成的信息混合。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715818_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.818334+00:00","actor":{},"payload":{"claim_id":"C8","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"自注意力提高并行化","statement":"自注意力层在训练样本内部不需要沿序列位置顺序计算，因此比循环层具有更高的并行化能力。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715863_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.863630+00:00","actor":{},"payload":{"claim_id":"C9","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"自注意力缩短依赖路径","statement":"自注意力层中任意两个序列位置之间的最大路径长度为常数，这比循环层和普通卷积层更有利于学习长距离依赖。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715953_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.953625+00:00","actor":{},"payload":{"claim_id":"C10","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"自注意力复杂度适合机器翻译长度","statement":"当序列长度 n 小于表示维度 d 时，自注意力层的计算复杂度低于循环层，而这是机器翻译中常见的设置。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780796715992_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:15.992773+00:00","actor":{},"payload":{"claim_id":"C11","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"英语到德语达到更高 BLEU","statement":"Transformer big 在 WMT 2014 English-to-German 任务上达到 28.4 BLEU，超过此前报告的最佳模型和集成模型。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780796716028_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:16.028657+00:00","actor":{},"payload":{"claim_id":"C12","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"英语到法语达到单模型领先结果","statement":"Transformer big 在 WMT 2014 English-to-French 任务上报告了新的单模型领先 BLEU 结果。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780796716064_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:16.064208+00:00","actor":{},"payload":{"claim_id":"C13","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"训练成本显著降低","statement":"Transformer 在达到上述机器翻译结果时所需训练成本低于此前竞争模型，big 模型在 8 块 P100 GPU 上训练约 3.5 天。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780796716101_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:16.101264+00:00","actor":{},"payload":{"claim_id":"C14","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"基础模型也具竞争力","statement":"Transformer base 在 WMT 2014 English-to-German 上超过此前已发表模型和集成模型，同时训练成本更低。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780796716137_68563","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Q53UKL5","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T01:45:16.137807+00:00","actor":{},"payload":{"claim_id":"C15","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"架构可迁移到解析任务","statement":"Transformer 不只适用于机器翻译，还能在英语成分句法分析任务上取得成功，包括大数据和有限数据设置。","type":"evidence","source":"paper"}}
