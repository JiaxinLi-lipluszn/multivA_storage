{"schema_version":1,"id":"evt_1780867785400_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.400790+00:00","actor":{},"payload":{"claim_id":"C6","seminar_id":"S1","paper_id":"deag018","by":"file","title":"核心安全结局","statement":"指南把中重度卵巢过度刺激综合征发生率作为主要安全结局。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785435_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.435198+00:00","actor":{},"payload":{"claim_id":"C7","seminar_id":"S1","paper_id":"deag018","by":"file","title":"推荐强度框架","statement":"每条证据型推荐被标记为强推荐或条件推荐，强推荐默认适用于多数情境，条件推荐需要根据具体风险收益判断。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785470_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.470246+00:00","actor":{},"payload":{"claim_id":"C8","seminar_id":"S1","paper_id":"deag018","by":"file","title":"证据质量偏低","statement":"指南中的证据型推荐没有任何一条由高质量证据支持，大多数依赖低质量或极低质量证据。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785507_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.507349+00:00","actor":{},"payload":{"claim_id":"C9","seminar_id":"S1","paper_id":"deag018","by":"file","title":"反应预测指标","statement":"AFC 或 AMH 被推荐用于预测卵巢刺激中的高反应或低反应。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785545_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.545657+00:00","actor":{},"payload":{"claim_id":"C10","seminar_id":"S1","paper_id":"deag018","by":"file","title":"非反应预测指标","statement":"年龄、BMI、基础 FSH、抑制素 B、基础雌二醇、基础孕酮和基础 LH 不被推荐用于预测卵巢反应。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785582_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.582112+00:00","actor":{},"payload":{"claim_id":"C11","seminar_id":"S1","paper_id":"deag018","by":"file","title":"活产预测边界","statement":"AFC、AMH 及多项基础激素指标不被推荐用于预测妊娠或活产。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785618_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.618824+00:00","actor":{},"payload":{"claim_id":"C12","seminar_id":"S1","paper_id":"deag018","by":"file","title":"年龄与 BMI","statement":"女性年龄和 BMI 被视为妊娠和活产的预测因素。","type":"core","source":"paper"}}
