{"schema_version":1,"id":"evt_1780867785692_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.692452+00:00","actor":{},"payload":{"claim_id":"C14","seminar_id":"S1","paper_id":"deag018","by":"file","title":"雌激素预处理","statement":"在 GnRH 拮抗剂方案前使用雌激素预处理不被推荐用于提高疗效。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785727_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.727823+00:00","actor":{},"payload":{"claim_id":"C15","seminar_id":"S1","paper_id":"deag018","by":"file","title":"COCP 预处理","statement":"在 GnRH 拮抗剂方案加单独 FSH 刺激中，COCP 预处理因降低疗效而不被推荐。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785764_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.764066+00:00","actor":{},"payload":{"claim_id":"C16","seminar_id":"S1","paper_id":"deag018","by":"file","title":"高反应者方案","statement":"预测为高反应者时，GnRH 拮抗剂方案被推荐作为刺激方案。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785800_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.800456+00:00","actor":{},"payload":{"claim_id":"C17","seminar_id":"S1","paper_id":"deag018","by":"file","title":"高反应者剂量","statement":"预测为高反应者时，较低促性腺激素剂量 100 至小于 150 IU 可能被推荐用于降低 OHSS 风险。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785835_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.836003+00:00","actor":{},"payload":{"claim_id":"C18","seminar_id":"S1","paper_id":"deag018","by":"file","title":"正常反应者剂量","statement":"预测为正常反应者时，低于或高于常规剂量的促性腺激素方案都不被推荐优于 150 至 225 IU 等效常规剂量。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785874_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.874083+00:00","actor":{},"payload":{"claim_id":"C19","seminar_id":"S1","paper_id":"deag018","by":"file","title":"低反应者高剂量边界","statement":"预测为低反应者时，不推荐使用高于 300 IU 的促性腺激素剂量。","type":"core","source":"paper"}}
