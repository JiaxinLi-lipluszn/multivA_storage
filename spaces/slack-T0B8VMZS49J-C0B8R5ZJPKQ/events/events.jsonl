{"schema_version":1,"id":"evt_1780787965631_29833","type":"paper_recorded","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:25.631379+00:00","actor":{},"payload":{"seminar_id":"S1","paper_id":"1706.03762","title":"1706.03762","url":"https://arxiv.org/abs/1706.03762"}}
{"schema_version":1,"id":"evt_1780787994665_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:54.665489+00:00","actor":{},"payload":{"claim_id":"C1","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"纯注意力架构","statement":"Transformer 是一个不使用循环网络或卷积网络、仅依赖注意力机制的序列转导架构。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780787994795_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:54.795098+00:00","actor":{},"payload":{"claim_id":"C2","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"编码器解码器可由注意力堆栈实现","statement":"由多头自注意力层和逐位置前馈网络堆叠而成的编码器-解码器结构足以完成机器翻译等序列到序列任务。","type":"core","source":"paper"}}
{"schema_version":1,"id":"evt_1780787994916_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:54.916792+00:00","actor":{},"payload":{"claim_id":"C3","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"训练可并行化","statement":"由于 Transformer 不按序列位置递归计算隐藏状态，它在单个训练样本内部可以比循环模型进行显著更多的并行计算。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995040_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.040187+00:00","actor":{},"payload":{"claim_id":"C4","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"自注意力缩短依赖路径","statement":"自注意力层使任意两个序列位置之间的信息交互只需常数级路径长度，而不是像循环或卷积结构那样随距离增长。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995168_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.168114+00:00","actor":{},"payload":{"claim_id":"C5","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"自注意力复杂度优势有条件成立","statement":"当序列长度 n 小于表示维度 d 时，自注意力层的计算复杂度相对于循环层更有优势，而这正是常见机器翻译表示中的典型情况。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995294_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.294174+00:00","actor":{},"payload":{"claim_id":"C6","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"缩放点积注意力必要性","statement":"在点积注意力中除以 sqrt(dk) 可以缓解大维度键查询点积过大导致 softmax 梯度过小的问题。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995417_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.417633+00:00","actor":{},"payload":{"claim_id":"C7","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"点积注意力效率优势","statement":"缩放点积注意力在理论复杂度相近的情况下，比加性注意力更适合用高效矩阵乘法实现，因此实践中更快、更省空间。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995545_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.545264+00:00","actor":{},"payload":{"claim_id":"C8","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"多头注意力作用","statement":"多头注意力通过在不同学习到的子空间中并行执行注意力，使模型能够同时关注不同位置和不同表示子空间的信息。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995671_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.671759+00:00","actor":{},"payload":{"claim_id":"C9","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"多头缓解单头平均问题","statement":"相比单个注意力头，多头注意力能缓解注意力加权平均导致的有效分辨率下降。","type":"concept","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995795_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.795780+00:00","actor":{},"payload":{"claim_id":"C10","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"解码器因果掩码","statement":"解码器自注意力必须屏蔽当前位置之后的目标词，以保证第 i 个位置的预测只依赖已知的较早输出。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787995931_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:55.931533+00:00","actor":{},"payload":{"claim_id":"C11","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"位置编码必要性","statement":"由于模型没有循环或卷积结构，必须向输入嵌入中加入位置编码，模型才能利用 token 的顺序信息。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996074_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.074617+00:00","actor":{},"payload":{"claim_id":"C12","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"正弦位置编码选择","statement":"正弦和余弦位置编码被选择，是因为作者假设它能让模型更容易学习相对位置关系，并可能泛化到训练时未见过的更长序列。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996218_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.218634+00:00","actor":{},"payload":{"claim_id":"C13","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"德语翻译核心结果","statement":"Transformer big 在 WMT 2014 英译德任务上达到 28.4 BLEU，超过此前已报道最佳结果包括集成模型超过 2 BLEU。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996360_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.360320+00:00","actor":{},"payload":{"claim_id":"C14","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"基础模型成本效果","statement":"Transformer base 在 WMT 2014 英译德任务上超过此前已发表模型和集成模型，同时训练成本显著更低。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996499_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.499403+00:00","actor":{},"payload":{"claim_id":"C15","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"法语翻译结果","statement":"Transformer big 在 WMT 2014 英译法任务上达到论文报告的单模型最高水平 BLEU，并且训练成本低于此前最强模型。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996638_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.638134+00:00","actor":{},"payload":{"claim_id":"C16","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"训练效率主张","statement":"Transformer base 可在 8 块 P100 GPU 上约 12 小时训练完成并达到强机器翻译效果，而 big 模型约 3.5 天训练完成。","type":"evidence","source":"paper"}}
{"schema_version":1,"id":"evt_1780787996773_29833","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8R5ZJPKQ","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-06T23:19:56.774003+00:00","actor":{},"payload":{"claim_id":"C17","seminar_id":"S1","paper_id":"1706.03762","by":"paper","title":"跨任务泛化","statement":"Transformer 不仅适用于机器翻译，也能成功应用于英语成分句法分析，包括大数据和有限数据设置。","type":"evidence","source":"paper"}}
