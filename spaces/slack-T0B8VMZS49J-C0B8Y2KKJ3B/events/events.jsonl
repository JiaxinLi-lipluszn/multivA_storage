{"schema_version":1,"id":"evt_1780867785295_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.295923+00:00","actor":{},"payload":{"claim_id":"C3","seminar_id":"S1","paper_id":"deag018","by":"file","title":"更新来源","statement":"2025 更新是在 2019 版指南基础上修订关键问题、拆分生育力保存问题，并加入若干新干预措施后形成的。","type":"method","source":"paper"}}
{"schema_version":1,"id":"evt_1780867785330_6446","type":"claim_created","space_id":"slack:T0B8VMZS49J:C0B8Y2KKJ3B","seminar_id":"S1","visibility":"seminar","created_at":"2026-06-07T21:29:45.330923+00:00","actor":{},"payload":{"claim_id":"C4","seminar_id":"S1","paper_id":"deag018","by":"file","title":"证据检索窗口","statement":"指南纳入的是 2018 年 10 月 31 日至 2025 年 2 月 2 日之间发表的英文文献。","type":"method","source":"paper"}}
